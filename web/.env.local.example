# Supabase (무료 DB) — https://supabase.com 에서 프로젝트 생성 후 입력
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 서버 전용 — Supabase Settings → API → service_role (절대 공개 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 관리자 분석 페이지 비밀번호 (발표/연구 담당자만 알도록)
ADMIN_SECRET=change-me-to-a-strong-password
