# Supabase (무료 DB) — https://supabase.com 에서 프로젝트 생성 후 입력
# 반드시 https:// 를 포함한 전체 URL 이어야 합니다. (예: https://abcdxyz.supabase.co)
# 따옴표·공백 없이 값만 입력하세요. Vercel 환경변수에도 동일하게 설정합니다.
#
# 등록 후 Vercel 반영:
#   node scripts/push-env-vercel.mjs
#   npx vercel --prod --yes
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 서버 전용 — Supabase Settings → API → service_role (절대 공개 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 관리자 분석 페이지 비밀번호 (발표/연구 담당자만 사용)
ADMIN_SECRET=change-me-to-a-strong-password

# (선택) 링크 미리보기 기본 URL — 미설정 시 https://ttwc.vercel.app
# NEXT_PUBLIC_SITE_URL=https://ttwc.vercel.app
